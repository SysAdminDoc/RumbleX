{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "3.29.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "author": "SysAdminDoc",
  "homepage_url": "https://github.com/SysAdminDoc/RumbleX",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "offscreen",
    "contextMenus",
    "scripting",
    "tabs",
    "tabGroups",
    "sidePanel",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://*.rumble.com/*",
    "*://*.1a-1791.com/*",
    "*://*.rumble.cloud/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'"
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "__MSG_actionTitle__",
    "default_popup": "pages/popup.html"
  },
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "pages/options.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.rumble.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/mux.min.js",
        "lib/mediabunny.min.mjs",
        "lib/mediabunny.LICENSE",
        "worker.js",
        "offscreen.html"
      ],
      "matches": [
        "*://*.rumble.com/*"
      ]
    }
  ]
}

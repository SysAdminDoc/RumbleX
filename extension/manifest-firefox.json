{
  "manifest_version": 2,
  "name": "__MSG_extName__",
  "version": "3.16.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "author": "SysAdminDoc",
  "homepage_url": "https://github.com/SysAdminDoc/RumbleX",
  "icons": {
    "16": "icons/icon-16x16.png",
    "32": "icons/icon-32x32.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "contextMenus",
    "alarms",
    "notifications",
    "*://*.rumble.com/*",
    "*://*.1a-1791.com/*",
    "*://*.rumble.cloud/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "rumblex@sysadmindoc",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_security_policy": "script-src 'self'; object-src 'self'; base-uri 'self'",
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16x16.png",
      "32": "icons/icon-32x32.png"
    },
    "default_title": "__MSG_actionTitle__",
    "default_popup": "pages/popup.html"
  },
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  },
  "content_scripts": [{
    "matches": ["*://*.rumble.com/*"],
    "js": ["content.js"],
    "run_at": "document_start",
    "all_frames": false
  }],
  "web_accessible_resources": [
    "lib/mux.min.js",
    "worker.js"
  ]
}